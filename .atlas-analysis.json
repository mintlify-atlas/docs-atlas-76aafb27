  "keyFeatures": [
    "Real-time collaborative whiteboarding using tldraw and Yjs",
    "Server/workspace management with invite system",
    "Role-based access control (Admin, Moderator, Guest)",
    "User authentication via Clerk",
    "File upload support with uploadthing",
    "WebSocket-based real-time synchronization",
    "Member management and permissions",
    "Dark mode support"
  ],
  "publicApiSurface": [
    "GET /api/servers - List all servers",
    "GET /api/servers/[serverId] - Get server details",
    "POST /api/servers - Create new server",
    "PATCH /api/servers/[serverId] - Update server",
    "DELETE /api/servers/[serverId] - Delete server",
    "PATCH /api/servers/[serverId]/invite-code - Generate new invite code",
    "PATCH /api/servers/[serverId]/leave - Leave server",
    "PATCH /api/members/[memberId] - Update member role",
    "DELETE /api/members/[memberId] - Remove member",
    "GET /api/profile - Get current user profile",
    "useYjsStore - Custom hook for real-time collaborative store"
  ]
